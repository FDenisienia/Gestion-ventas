# Configuración del servidor
PORT=3001

# JWT Secret (CAMBIAR EN PRODUCCIÓN)
JWT_SECRET=tu-secreto-super-seguro-cambiar-en-produccion-minimo-32-caracteres

# Tiempo de expiración del token JWT
JWT_EXPIRES_IN=24h

# URL del frontend para CORS (puede ser múltiples URLs separadas por coma)
# Ejemplo: FRONTEND_URL=http://localhost:5173,https://gestion-ventas1.netlify.app
FRONTEND_URL=http://localhost:5173,https://gestion-ventas1.netlify.app

# URL de Netlify (opcional, para permitir automáticamente)
NETLIFY_URL=https://gestion-ventas1.netlify.app

# Permitir cualquier origen (solo para desarrollo/testing)
# En producción, es mejor especificar las URLs exactas en FRONTEND_URL
# ALLOW_ALL_ORIGINS=true

# Entorno
NODE_ENV=development
